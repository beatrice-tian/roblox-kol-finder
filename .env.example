# 网络代理（Clash Verge 混合端口；需已安装 PySocks：python -m pip install PySocks）
PROXY_URL=http://127.0.0.1:7897

# YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key

# OpenAI（用于 AI 合作建议；留空则使用规则模板）
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# 逗号分隔：youtube,tiktok（tiktok 尚未实现）
ENABLED_PLATFORMS=youtube

# 字幕抓取（安全模式：每 creator 最多 2 条高播放视频，单次 run 上限 20 次请求；需 PROXY_URL 走 Clash）
TRANSCRIPT_ENABLED=true
TRANSCRIPT_VIDEOS_PER_CREATOR=2
TRANSCRIPT_MAX_REQUESTS=20
TRANSCRIPT_USE_CACHE=true

# 预留 TikTok
# TIKTOK_ACCESS_TOKEN=

# Web 情报流预览（需先存在 output/roblox_kol_report.csv）
# python -m src.web.build
# python -m src.web.serve

# Vercel 部署：根目录 vercel.json 已指向 web/；部署前确保 web/data/reports/ 与 index.json 已生成并提交
